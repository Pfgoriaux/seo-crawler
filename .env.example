# SEO Crawler Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Crawler Settings
# ===========================================

# Number of concurrent pages to crawl (default: 3)
CRAWLER_CONCURRENCY=3

# Timeout for each page in milliseconds (default: 30000)
CRAWLER_TIMEOUT=30000

# Default output directory for reports
CRAWLER_OUTPUT_DIR=./seo-reports

# Custom user agent string
CRAWLER_USER_AGENT=SEO-Crawler/1.0 (https://github.com/pfgope/seo-crawler)

# ===========================================
# AI Improvement Agent Settings
# ===========================================

# Anthropic Claude API Key (required for AI-powered improvements)
ANTHROPIC_API_KEY=

# Claude model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Maximum tokens for AI responses (default: 4096)
CLAUDE_MAX_TOKENS=4096

# ===========================================
# Advanced Settings
# ===========================================

# Enable debug logging (true/false)
DEBUG_MODE=false

# Browser viewport width (default: 1920)
VIEWPORT_WIDTH=1920

# Browser viewport height (default: 1080)
VIEWPORT_HEIGHT=1080

# Check for broken links (true/false, default: true)
CHECK_BROKEN_LINKS=true
